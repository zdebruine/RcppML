PKG_CPPFLAGS = -I../inst/include/
PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS) $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)

## Compiler flags
## Set -O3 in ~/.R/Makevars for local optimization (non-portable for CRAN)
PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS) -DEIGEN_INITIALIZE_MATRICES_BY_ZERO -DEIGEN_NO_DEBUG -DSPARSEPRESS_USE_R -DFACTORNET_USE_R
